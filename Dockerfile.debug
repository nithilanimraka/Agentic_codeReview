# ---- Base layer ----------------------------------------------------------
FROM python:3.12.10-slim AS base
ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1 PIP_NO_CACHE_DIR=1
RUN apt-get update && apt-get install -y --no-install-recommends build-essential git && rm -rf /var/lib/apt/lists/*

# ---- Python deps ---------------------------------------------------------
WORKDIR /app
COPY requirements.txt .
RUN pip install --upgrade pip && pip install -r requirements.txt

# ---- App code ------------------------------------------------------------
COPY . .
RUN mkdir -p /models
ENV TRANSFORMERS_CACHE=/models          
EXPOSE 8000

# --- START OF CHANGES FOR DEBUG ---
# 1. Copy the diagnostic script and make sure it's executable
COPY diagnostic-start.sh .
RUN chmod +x diagnostic-start.sh

# 2. Change the CMD to run the diagnostic script
CMD ["./diagnostic-start.sh"]
# --- END OF CHANGES FOR DEBUG ---